# Cognito Enterprise Server — Environment Variables
# Copy this to .env and fill in your values

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=8787
NODE_ENV=development

# ─── AI Providers (at least one required) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ─── Security ─────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a strong random secret in production!
JWT_SECRET=cognito-enterprise-change-this-secret-in-production
JWT_EXPIRES=7d

# ─── Database ──────────────────────────────────────────────────────────────────
# Directory for SQLite database file
DB_DIR=./data

# ─── File Storage ─────────────────────────────────────────────────────────────
# Directory for uploaded files
UPLOAD_DIR=./uploads

# Maximum file size for uploads (MB)
MAX_FILE_MB=100

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# General API rate limit
RATE_LIMIT_WINDOW_MS=86400000
RATE_LIMIT_MAX=100

# AI analysis rate limit (per hour)
ANALYSIS_RATE_LIMIT=20

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:8787

# ─── Models ────────────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.5-flash
OPENAI_TIMEOUT_MS=60000
GEMINI_TIMEOUT_MS=60000

# ─── Proxy ─────────────────────────────────────────────────────────────────────
# TRUST_PROXY=loopback  # Enable when behind Nginx/ALB
