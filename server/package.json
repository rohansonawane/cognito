{
  "name": "ai-canvas-server",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --watch ./src/index.js",
    "dev:enterprise": "node --env-file=.env --watch ./src/index-enterprise.js",
    "start": "node ./src/index.js",
    "start:enterprise": "node ./src/index-enterprise.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.933.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "uuid": "^13.0.0"
  }
}
